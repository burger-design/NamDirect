rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidFarmer(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) && 
             data.uid is string && 
             data.email is string &&
             data.createdAt is string;
    }

    match /farmers/{farmerId} {
      allow read: if true;
      allow create: if isOwner(farmerId) && isValidFarmer(incoming());
      allow update: if isOwner(farmerId);
      allow delete: if isOwner(farmerId);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role == 'customer';
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['farmerId', 'name', 'price', 'unit', 'category', 'stockStatus']) &&
             data.farmerId is string &&
             data.name is string &&
             data.price is number &&
             data.unit is string &&
             data.category is string &&
             data.stockStatus is bool;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().farmerId == request.auth.uid && isValidProduct(incoming());
      allow update: if isSignedIn() && existing().farmerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().farmerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        existing().customerId == request.auth.uid || 
        existing().farmerId == request.auth.uid
      );
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid;
      allow update: if isSignedIn() && (
        existing().customerId == request.auth.uid || 
        existing().farmerId == request.auth.uid
      );
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
